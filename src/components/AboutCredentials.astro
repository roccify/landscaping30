---
import content from '../data/content.json';
import Icon from './Icon.astro';
const credentials = content.about.credentials;
---

<section class="py-16 md:py-24 bg-brand-900 grain-overlay relative">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center mb-10">
 <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Credentials & Values</h2>
 </div>

 <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6 max-w-4xl mx-auto">
 {credentials.map((cred, i) => (
 <div
 class="group text-center bg-white/5 backdrop-blur-sm rounded-xl p-6 border border-gray-700 hover:border-brand-400 transition-all duration-300"


 >
 <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center mx-auto mb-3 transition-transform duration-300 group-hover:scale-110">
 <Icon name={cred.icon} class="w-5 h-5 text-brand-400" />
 </div>
 <p class="text-white font-medium text-sm sm:text-base">{cred.text}</p>
 </div>
 ))}
 </div>
 </div>
</section>

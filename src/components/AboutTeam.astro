---
import content from '../data/content.json';
const team = content.about.team;
---

<section class="py-16 md:py-24 bg-gray-50">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center mb-10">
 <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Team</h2>
 </div>

 <div class="max-w-4xl mx-auto">
 <div class="rounded-xl overflow-hidden shadow-lg mb-8">
 <img
 src={team.image.url}
 alt={team.image.alt}
 class="w-full h-auto object-cover aspect-[16/9]"
 loading="lazy"
 onerror={`this.style.display='none';this.parentElement.style.background='${team.image.fallback}'`}
 />
 </div>
 <p class="text-gray-600 leading-relaxed text-center text-lg max-w-3xl mx-auto">{team.description}</p>
 </div>
 </div>
</section>

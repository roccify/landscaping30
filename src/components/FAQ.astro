---
import content from '../data/content.json';
const faq = content.faq || [];
const showFaq = faq.length > 0;
---

{showFaq && (
  <section class="py-10 md:py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
        <p class="text-gray-500 max-w-xl mx-auto">Quick answers to common questions about our landscaping services.</p>
      </div>

      <div class="space-y-3">
        {faq.map((item, i) => (
          <div class="faq-item border border-gray-200 rounded-xl overflow-hidden">
            <button
              class="faq-trigger w-full flex items-center justify-between px-6 py-5 text-left font-semibold text-gray-900 hover:bg-gray-50 transition-colors"
              data-faq-index={String(i)}
            >
              <span>{item.question}</span>
              <svg class="faq-icon w-5 h-5 text-gray-400 flex-shrink-0 ml-4 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <p class="text-gray-600 leading-relaxed">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

---
import content from '../data/content.json';
const c = content.contact;
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-400 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <a href="/" class="font-display text-xl font-bold text-white block mb-2">{content.shortName}</a>
    <p class="text-sm mb-4">{content.tagline}</p>
    <p class="text-sm mb-1"><a href={c.phoneClick} class="hover:text-brand-400">{c.phoneDisplay}</a></p>
    <p class="text-sm mb-1"><a href={`mailto:${c.email}`} class="hover:text-brand-400">{c.email}</a></p>
    <p class="text-sm mb-6">{c.address}</p>
    <p class="text-gray-600 text-xs">&copy; {currentYear} {content.footer.copyright}</p>
  </div>
</footer>

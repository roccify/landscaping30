---
import content from '../data/content.json';
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-brand-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="font-display font-bold text-xl text-white">{content.shortName}</a>
      <div class="flex items-center gap-4 sm:gap-6">
        <a href="/" class="text-white text-sm font-medium hidden sm:block">Home</a>
        <a href="/services" class="text-white text-sm font-medium hidden sm:block">Services</a>
        <a href="/about" class="text-white text-sm font-medium hidden sm:block">About</a>
        <a href="/contact" class="text-white text-sm font-medium hidden sm:block">Contact</a>
        <a href={content.contact.phoneClick} class="bg-brand-600 text-white px-4 py-2 rounded-lg font-semibold text-sm">{content.contact.phoneDisplay}</a>
      </div>
    </div>
  </div>
</header>

---
import content from '../data/content.json';
import Icon from './Icon.astro';
const area = content.serviceArea || null;
const showArea = area && area.cities && area.cities.length > 0;
---

{showArea && (
  <section class="py-12 md:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">{area.headline}</h2>
        <p class="text-gray-500 max-w-xl mx-auto">{area.subheadline}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-3xl mx-auto">
        {area.cities.map((city) => (
          <div class="flex items-center gap-2 bg-white rounded-lg px-4 py-3 border border-gray-200 shadow-sm">
            <Icon name="pin" class="w-4 h-4 text-brand-600 flex-shrink-0" />
            <span class="text-gray-800 font-medium text-sm">{city}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

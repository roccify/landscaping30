---
import Icon from './Icon.astro';

interface Props {
 service: {
 id: string;
 name: string;
 icon: string;
 image: { url: string; alt: string; fallback: string };
 problem: string[];
 solution: string[];
 benefits: string[];
 };
 index: number;
}

const { service, index } = Astro.props;
const isEven = index % 2 === 0;
---

<section id={service.id} class={`py-16 md:py-20 ${isEven ? 'bg-white' : 'bg-gray-50'} scroll-mt-24`}>
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <!-- Header with image -->
 <div class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 mb-12`}>
 <!-- Image -->
 <div class="lg:w-5/12">
 <div class="rounded-xl overflow-hidden shadow-lg aspect-[4/3]" style={`background: ${service.image.fallback}`}>
 <img
 src={service.image.url}
 alt={service.image.alt}
 class="w-full h-full object-cover"
 loading="lazy"
 onerror="this.style.display='none'"
 />
 </div>
 </div>

 <!-- Title + Problem -->
 <div class="lg:w-7/12">
 <div class="flex items-center gap-3 mb-4">
 <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0">
 <Icon name={service.icon} class="w-5 h-5 text-brand-600" />
 </div>
 <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900">{service.name}</h2>
 </div>

 <div class="space-y-4">
 {service.problem.map((p) => (
 <p class="text-gray-600 leading-relaxed">{p}</p>
 ))}
 </div>
 </div>
 </div>

 <!-- Solution -->
 <div class="max-w-4xl mx-auto mb-10">
 <h3 class="font-display text-xl md:text-2xl font-semibold text-gray-900 mb-4">How We Solve It</h3>
 <div class="space-y-4">
 {service.solution.map((s) => (
 <p class="text-gray-600 leading-relaxed">{s}</p>
 ))}
 </div>
 </div>

 <!-- Benefits -->
 <div class="max-w-4xl mx-auto mb-10">
 <h3 class="font-display text-xl md:text-2xl font-semibold text-gray-900 mb-4">Why Choose Us for {service.name}</h3>
 <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
 {service.benefits.map((b) => (
 <div class="flex items-start gap-3 bg-brand-50 rounded-lg p-4">
 <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
 <span class="text-gray-800 font-medium">{b}</span>
 </div>
 ))}
 </div>
 </div>

 <!-- CTA -->
 <div class="max-w-4xl mx-auto text-center">
 <a href="/contact" class="inline-block bg-brand-600 hover:bg-brand-700 text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all hover:shadow-lg hover:-translate-y-0.5">
 Get a Free Quote
 </a>
 </div>
 </div>
</section>

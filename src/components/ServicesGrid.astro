---
import content from '../data/content.json';
import Icon from './Icon.astro';

const displayIds = content.homepageServiceIds;
const services = content.services.filter(s => displayIds.includes(s.id));
---

<section class="py-12 md:py-16 bg-gray-50">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center mb-12">
 <h2 class="font-display text-3xl md:text-4xl font-bold text-gray-900 mb-4">What We Do</h2>
 <p class="text-gray-500 max-w-xl mx-auto">Comprehensive landscaping services for residential and commercial properties across the Madison area.</p>
 </div>

 <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-7">
 {services.map((service, i) => (
 <a
 href={`/services#${service.id}`}
 class="group bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 flex flex-col"


 >
 <!-- Service image -->
 <div class="relative h-32 sm:h-52 overflow-hidden" style={`background: ${service.image.fallback}`}>
 <img
 src={service.image.url}
 alt={service.image.alt}
 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"

 onerror="this.style.display='none'"
 />
 </div>

 <div class="p-4 sm:p-6 flex flex-col flex-1">
 <!-- Icon -->
 <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center mb-4">
 <Icon name={service.icon} class="w-5 h-5 text-brand-600" />
 </div>

 <h3 class="font-display text-xl font-semibold text-gray-900 mb-2 group-hover:text-brand-700 transition-colors">
 {service.name}
 </h3>
 <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">{service.shortDescription}</p>
 <span class="inline-flex items-center text-brand-600 font-semibold text-sm group-hover:gap-2 transition-all">
 Learn More
 <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
 </span>
 </div>
 </a>
 ))}
 <!-- Invisible spacer — iOS Safari workaround -->
 <div aria-hidden="true" style="height:1px;overflow:hidden;opacity:0;pointer-events:none;"></div>
 </div>
 </div>
</section>

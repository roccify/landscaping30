---
import content from '../data/content.json';
import Icon from './Icon.astro';
const items = content.whyChooseUs;
---

<section class="py-8 md:py-16 bg-brand-900 grain-overlay relative">
 <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
 <div class="text-center mb-8">
 <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Why Choose Us</h2>
 <p class="text-brand-200 opacity-60 max-w-xl mx-auto">Reliable service backed by clear communication, proper licensing, and years of local experience.</p>
 </div>

 <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-6 max-w-4xl mx-auto">
 {items.map((item, i) => (
 <div
 class="group text-center bg-white/5 backdrop-blur-sm rounded-xl p-4 md:p-8 border border-gray-700 hover:border-brand-400 hover:bg-white/10 transition-all duration-300"
 >
 <div class="w-10 h-10 md:w-14 md:h-14 bg-white/10 rounded-xl flex items-center justify-center mx-auto mb-3 md:mb-4 transition-transform duration-300 group-hover:scale-110">
 <Icon name={item.icon} class="w-5 h-5 md:w-6 md:h-6 text-brand-400" />
 </div>
 <p class="text-white font-semibold text-sm md:text-base">{item.text}</p>
 </div>
 ))}
 </div>
 </div>
</section>

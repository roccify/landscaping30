---
import content from '../data/content.json';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
 title: string;
 description: string;
 ogImage?: string;
 page: 'home' | 'services' | 'about' | 'contact';
}

const { title, description, ogImage, page } = Astro.props;
const siteUrl = Astro.url.origin;
const currentUrl = Astro.url.href;
const firstLetter = content.shortName.charAt(0);

// JSON-LD LocalBusiness
const jsonLd = {
 "@context": "https://schema.org",
 "@type": "LocalBusiness",
 "name": content.businessName,
 "image": content.heroes.home.image.url,
 "telephone": content.contact.phoneClick.replace('tel:', ''),
 "email": content.contact.email,
 "address": {
 "@type": "PostalAddress",
 "streetAddress": "2318 Mustang Way",
 "addressLocality": "Madison",
 "addressRegion": "WI",
 "postalCode": "53718",
 "addressCountry": "US"
 },
 "url": siteUrl,
 "areaServed": content.contact.serviceArea,
 "openingHours": ["Mo-Fr 07:00-18:00", "Sa 08:00-14:00"],
 "priceRange": "$$"
};

// Breadcrumb JSON-LD
const breadcrumbItems = [
 { name: "Home", url: siteUrl },
];
if (page === 'services') breadcrumbItems.push({ name: "Services", url: `${siteUrl}/services` });
if (page === 'about') breadcrumbItems.push({ name: "About", url: `${siteUrl}/about` });
if (page === 'contact') breadcrumbItems.push({ name: "Contact", url: `${siteUrl}/contact` });

const breadcrumbLd = {
 "@context": "https://schema.org",
 "@type": "BreadcrumbList",
 "itemListElement": breadcrumbItems.map((item, i) => ({
 "@type": "ListItemElement",
 "position": i + 1,
 "name": item.name,
 "item": item.url
 }))
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0" />
 <title>{title}</title>
 <meta name="description" content={description} />

 <!-- Open Graph -->
 <meta property="og:title" content={title} />
 <meta property="og:description" content={description} />
 <meta property="og:type" content="website" />
 <meta property="og:url" content={currentUrl} />
 {ogImage && <meta property="og:image" content={ogImage} />}

 <!-- Twitter Card -->
 <meta name="twitter:card" content="summary_large_image" />
 <meta name="twitter:title" content={title} />
 <meta name="twitter:description" content={description} />
 {ogImage && <meta name="twitter:image" content={ogImage} />}

 <!-- Favicon — dynamic SVG from first letter -->
 <link rel="icon" type="image/svg+xml" href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='16' fill='%2316a34a'/><text x='50' y='72' font-size='60' font-family='Georgia,serif' font-weight='700' fill='white' text-anchor='middle'>${firstLetter}</text></svg>`} />
 <link rel="apple-touch-icon" href={`data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'><rect width='180' height='180' rx='28' fill='%2316a34a'/><text x='90' y='125' font-size='100' font-family='Georgia,serif' font-weight='700' fill='white' text-anchor='middle'>${firstLetter}</text></svg>`} />

 <!-- Fonts -->
 <link rel="preconnect" href="https://fonts.googleapis.com" />
 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
 <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

 <!-- JSON-LD -->
 <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
 <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

 <!-- Global styles -->
 <style is:global>
 body {
 font-family: 'Source Sans 3', system-ui, sans-serif;
 }

 /* Prevent iOS Safari from removing off-screen elements */
 section, .grid, .gallery-grid, .gallery-item, .gallery-row {
 content-visibility: visible !important;
 contain-intrinsic-size: auto;
 }

 /* Grain texture overlay for dark sections */
 .grain-overlay {
 position: relative;
 }
 .grain-overlay::after {
 content: '';
 position: absolute;
 inset: 0;
 opacity: 0.03;
 pointer-events: none;
 background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
 background-repeat: repeat;
 background-size: 256px;
 z-index: 1;
 }
 .grain-overlay > * {
 position: relative;
 z-index: 2;
 }

 /* Parallax hero backgrounds */
 .parallax-bg {
 background-attachment: fixed;
 background-position: center;
 background-size: cover;
 }
 @supports (-webkit-touch-callout: none) {
 .parallax-bg {
 background-attachment: scroll;
 }
 }

 /* Image fallback */
 .img-fallback {
 object-fit: cover;
 }

 /* Page fade in — REMOVED: causes iPhone Safari rendering issues */

 /* Scroll indicator bounce */
 @keyframes scrollBounce {
 0%, 100% { transform: translateY(0); }
 50% { transform: translateY(8px); }
 }
 .scroll-indicator {
 animation: scrollBounce 2s ease-in-out infinite;
 }

 /* Mobile sticky CTA slide up */
 @keyframes slideUp {
 from { transform: translateY(100%); }
 to { transform: translateY(0); }
 }
 .sticky-cta-animate {
 animation: slideUp 0.4s ease-out;
 }

 /* Count-up animation helper */
 .count-up {
 font-variant-numeric: tabular-nums;
 }
 </style>
</head>
<body class="font-body text-gray-800 bg-white antialiased">
 <Nav />

 <main>
 <slot />
 </main>

 <Footer />

 </body>
</html>

---
import Layout from '../layouts/Layout.astro';
import content from '../data/content.json';
---

<Layout title={`Page Not Found | ${content.businessName}`} description="The page you're looking for doesn't exist." page="home">
 <section class="min-h-[70vh] flex items-center justify-center bg-white">
 <div class="text-center px-6 py-24">
 <div class="font-display text-8xl md:text-9xl font-bold text-brand-200 mb-4">404</div>
 <h1 class="font-display text-2xl md:text-3xl font-bold text-gray-900 mb-4">
 Page Not Found
 </h1>
 <p class="text-gray-500 max-w-md mx-auto mb-8 leading-relaxed">
 Sorry, the page you're looking for doesn't exist or has been moved. Let's get you back on track.
 </p>
 <div class="flex flex-wrap gap-4 justify-center">
 <a href="/" class="inline-block bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-lg font-semibold transition-all hover:shadow-lg hover:-translate-y-0.5">
 Back to Home
 </a>
 <a href="/contact" class="inline-block bg-gray-100 hover:bg-gray-200 text-gray-800 px-6 py-3 rounded-lg font-semibold transition-all hover:-translate-y-0.5">
 Contact Us
 </a>
 </div>
 </div>
 </section>
</Layout>

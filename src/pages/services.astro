---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ServiceDetail from '../components/ServiceDetail.astro';
import CTA from '../components/CTA.astro';
import content from '../data/content.json';

const seo = content.seo.services;
const hero = content.heroes.services;
---

<Layout title={seo.title} description={seo.description} ogImage={seo.ogImage} page="services">
 <Hero
 headline={hero.headline}
 subheadline={hero.subheadline}
 image={hero.image}
 />

 <!-- Services intro -->
 <section class="py-16 md:py-20 bg-white">
 <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
 <p class="text-lg md:text-xl text-gray-600 leading-relaxed font-light">
 We offer a full range of landscaping services for residential and commercial properties in the Madison area. Click any service below to learn more about how we can help.
 </p>
 </div>
 </section>

 <!-- Individual services -->
 {content.services.map((service, index) => (
 <ServiceDetail service={service} index={index} />
 ))}

 <CTA />
</Layout>
